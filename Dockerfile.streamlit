FROM python:3.10-slim

WORKDIR /app

ENV PYTHONPATH=/app/src

# Streamlit + pandas chỉ cần cho dashboard benchmark, tách khỏi image runtime nhẹ.
RUN pip install --no-cache-dir streamlit pandas

COPY . /app

EXPOSE 8501

CMD ["streamlit", "run", "src/dashboard/benchmark_app.py", "--server.port=8501", "--server.address=0.0.0.0"]
